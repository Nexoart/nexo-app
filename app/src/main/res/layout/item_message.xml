<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="#080808">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardAvatar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        app:cardCornerRadius="26dp"
        app:cardBackgroundColor="#222222"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/imageProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/textName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ikusi"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/cardAvatar"
        app:layout_constraintBottom_toTopOf="@id/textMessage"
        app:layout_constraintStart_toEndOf="@id/cardAvatar"
        app:layout_constraintEnd_toStartOf="@id/iconStatus"
        app:layout_constraintVertical_chainStyle="packed"/>

    <TextView
        android:id="@+id/textMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Como combinamos a paleta de cores?"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/textName"
        app:layout_constraintBottom_toBottomOf="@id/cardAvatar"
        app:layout_constraintStart_toEndOf="@id/cardAvatar"
        app:layout_constraintEnd_toStartOf="@id/iconStatus"/>

    <!-- Ícone de status verde -->
    <androidx.cardview.widget.CardView
        android:id="@+id/iconStatus"
        android:layout_width="12dp"
        android:layout_height="12dp"
        app:cardCornerRadius="6dp"
        app:cardBackgroundColor="#1B5E20"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
