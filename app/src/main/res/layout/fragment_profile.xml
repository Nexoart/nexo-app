<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_glow"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="80dp">

        <!-- Header: Capa -->
        <ImageView
            android:id="@+id/imageCover"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/shiorivolt"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/color_border_dark"
            android:alpha="0.3"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Foto de Perfil com Borda -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfile"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="-50dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/color_bg_glow"
            app:layout_constraintTop_toBottomOf="@id/imageCover"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/imageProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:padding="3dp"
                android:src="@drawable/marcy" />
        </androidx.cardview.widget.CardView>

        <!-- Informações do Artista -->
        <TextView
            android:id="@+id/textArtistName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shiori Volt"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardProfile"
            app:layout_constraintStart_toStartOf="@id/cardProfile" />

        <TextView
            android:id="@+id/textArtistBio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Digital Artist | Cyberpunk &amp; Glitch Enthusiast"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/textArtistName"
            app:layout_constraintStart_toStartOf="@id/textArtistName"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Stats (Seguidores, Curtidas) -->
        <LinearLayout
            android:id="@+id/layoutStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/textArtistBio">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="32dp">
                <TextView
                    android:id="@+id/tvCountSeguidores"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12.5k"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="18sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seguidores"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvCountCurtidas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="48k"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="18sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Curtidas"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Botão Editar Perfil -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:text="Editar Perfil"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/color_primary"
            app:layout_constraintTop_toBottomOf="@id/layoutStats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Grid de Portfólio -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:padding="2dp"
            app:layout_constraintTop_toBottomOf="@id/buttonMessage" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>