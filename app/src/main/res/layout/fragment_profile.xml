<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header: ImageView de capa -->
        <ImageView
            android:id="@+id/imageCover"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:background="#1A1A1A"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Avatar: CardView circular sobrepondo a capa -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfileImageBorder"
            android:layout_width="104dp"
            android:layout_height="104dp"
            app:cardCornerRadius="52dp"
            app:cardBackgroundColor="#080808"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/imageCover"
            app:layout_constraintBottom_toBottomOf="@id/imageCover"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center"
                app:cardCornerRadius="48dp"
                app:cardBackgroundColor="#222222">
                
                <ImageView
                    android:id="@+id/imageProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>
                    
            </androidx.cardview.widget.CardView>
        </androidx.cardview.widget.CardView>

        <!-- Nome do artista -->
        <TextView
            android:id="@+id/textArtistName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rafilskz"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_marginStart="24dp"
            app:layout_constraintTop_toBottomOf="@id/cardProfileImageBorder"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Status Badge -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1B5E20"
            app:layout_constraintTop_toTopOf="@id/textArtistName"
            app:layout_constraintBottom_toBottomOf="@id/textArtistName"
            app:layout_constraintStart_toEndOf="@id/textArtistName"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢 Commissions Open"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </androidx.cardview.widget.CardView>

        <!-- Username -->
        <TextView
            android:id="@+id/textUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\@rafilskz"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/textArtistName"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Biografia -->
        <TextView
            android:id="@+id/textArtistBio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Olá eu me chamo rafilsk!!"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/textUsername"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Métricas -->
        <LinearLayout
            android:id="@+id/layoutMetrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@id/textArtistBio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Projetos -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvCountProjetos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Projetos"
                    android:textColor="#608358"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Seguidores -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvCountSeguidores"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seguidores"
                    android:textColor="#608358"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Curtidas -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvCountCurtidas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Curtidas"
                    android:textColor="#608358"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Botões CTA -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/layoutMetrics">

            <!-- Botão Seguir -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonFollow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Seguir"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1B5E20"
                app:cornerRadius="8dp" />

            <!-- Botão Mensagem -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Mensagem"
                android:textColor="#608358"
                app:backgroundTint="@android:color/transparent"
                app:strokeColor="#608358"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- Divisor -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/layoutActions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Grid (RecyclerView) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:clipToPadding="false"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
